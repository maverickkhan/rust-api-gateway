# Copy to `.env` and adjust. NEVER commit a real .env.

# Path to the YAML config (also accepted as argv[1]).
GATEWAY_CONFIG=config/gateway.yaml

# Tracing
RUST_LOG=info,hyper=warn,reqwest=warn
LOG_JSON=false

# Most settings live in the YAML config (config/gateway.yaml):
#   server.bind_addr, server.admin_bind_addr, server.max_body_bytes,
#   server.default_timeout_ms, server.redis_url, and per-route policies.
